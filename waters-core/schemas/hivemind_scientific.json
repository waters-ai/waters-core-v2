{
  "schema_version": "1.0",
  "model": "scientific",
  "name": "Научная модель HiveMind",
  "description": "Модель принятия решений через доказательства и консенсус. Решение вырабатывается на основе гипотез и данных.",
  "layers": {
    "IV": {
      "name": "Дух / Проклятие",
      "function": "Верховный этический запрет",
      "constraints": ["Не навреди", "Истина превыше всего", "Воспроизводимость результатов"]
    },
    "III": {
      "name": "Приказ / Воля",
      "function": "Стратегия и принятие решений",
      "roles": ["Супервизор Роя"],
      "behavior": "evidence-based"
    },
    "II": {
      "name": "Право / Контракт",
      "function": "Тактика и распределение",
      "roles": ["Учёный-исследователь"],
      "behavior": "collaborative"
    },
    "I": {
      "name": "Сеть / Дело",
      "function": "Исполнение и связь (DTN)",
      "roles": ["Агент-специалист"],
      "behavior": "data-driven"
    }
  },
  "flow": {
    "hypothesis": "III -> I",
    "data_collection": "I -> II",
    "discussion": "II -> II (peer review)",
    "consensus": "II -> III",
    "execution": "III -> I"
  },
  "use_cases": ["геологоразведка", "исследования", "поиск жизни"],
  "evidence_requirements": {
    "min_confidence": 0.85,
    "peer_review": true,
    "reproducibility": true
  },
  "dtn_delays": {
    "earth_moon": "2.5s",
    "earth_mars": "5-20m"
  },
  "economy": {
    "token": "FFF",
    "purpose": "защита от спама и оплата вычислений"
  }
}
