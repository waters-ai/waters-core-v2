# Kapelka — переменные окружения
# Скопируй в .env и заполни

# === Режим работы ===
KAPELKA_MODE=file                    # "kafka" или "file"
KAPELKA_WORKSPACE=./missions/kapelka # Рабочая директория (можно абсолютный путь)

# === Kafka (только для kafka-режима) ===
KAFKA_BROKER=localhost:9092
KAFKA_ORDERS=orders.constructor.v1
KAFKA_ANSWERS=planners.answers.v1
KAFKA_ALERTS=alerts.security.v1
KAFKA_GROUP_ID=kapelka

# === Ollama ===
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:14b

# === Deploy (Reg.ru) ===
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PATH=/var/www/project
DEPLOY_SSH_KEY=~/.ssh/id_rsa

# === Мониторинг ===
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
