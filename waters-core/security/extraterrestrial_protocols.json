{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.0",
  "name": "Неземные протоколы связи WATERS",
  "author": "Хранитель Протокола v1.0",
  "date": "07.05.2026",
  "scope": "Безопасная коммуникация в условиях задержек DTN и отсутствия постоянного соединения",

  "dtn_layers": {
    "physical": {
      "radio_bands": ["S-band", "X-band", "Ka-band", "optical"],
      "data_rates": {
        "earth_moon": "1-10 Mbps",
        "earth_mars": "0.1-3 Mbps",
        "earth_neptune": "0.001-0.1 Mbps"
      }
    },
    "bundle_protocol": {
      "version": "RFC 5050",
      "custody_transfer": true,
      "priority_levels": [0, 1, 2, 3, 4, 5, 6],
      "max_bundle_size_bytes": 1048576
    },
    "security": {
      "encryption": "AES-256-GCM over DTN",
      "authentication": "Ed25519 per bundle",
      "key_distribution": "Pre-shared keys + ECDH session keys",
      "anti_replay": "monotonic sequence numbers"
    }
  },

  "delay_scenarios": {
    "low_earth_orbit": "10-500ms",
    "lunar_surface": "1.3-2.6s",
    "mars_surface": "5-20m",
    "jupiter_orbit": "33-52m",
    "saturn_orbit": "67-84m",
    "neptune_orbit": "4-5h"
  },

  "security_threats": {
    "signal_interception": {
      "risk": "high",
      "mitigation": "end-to-end encryption (AES-256-GCM)"
    },
    "signal_jamming": {
      "risk": "medium",
      "mitigation": "frequency hopping + store-and-forward"
    },
    "bundle_replay": {
      "risk": "medium",
      "mitigation": "monotonic sequence numbers + timestamp validation"
    },
    "custody_chain_break": {
      "risk": "high",
      "mitigation": "multiple custody transfers + acknowledgment chain"
    },
    "agent_impersonation": {
      "risk": "critical",
      "mitigation": "Ed25519 signature verification + certificate pinning"
    }
  },

  "resilience": {
    "store_and_forward": true,
    "max_store_hours": 168,
    "retransmission_attempts": 3,
    "acknowledgment_required": true,
    "fallback_channels": ["deep_space_network", "relay_satellites", "laser_comm"]
  },

  "yasa_compliance": {
    "Не лжи": "Все bundles содержат криптографический хеш содержимого",
    "Держи слово": "Custody transfer = обязательство доставки",
    "Не вреди сородичу": "Jamming detection → alert → switch to backup channel",
    "Помогай слабому": "Priority routing for distressed agents"
  },

  "monitoring": {
    "metrics": ["bundle_loss_rate", "latency", "throughput", "security_events"],
    "alert_thresholds": {
      "bundle_loss_rate": 0.05,
      "latency_spike_percent": 200,
      "security_events_per_hour": 10
    },
    "reporting_topic": "alerts.security.v1"
  }
}
