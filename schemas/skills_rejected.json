{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skills Rejected",
  "type": "object",
  "properties": {
    "skill_id": { "type": "string" },
    "name": { "type": "string" },
    "rejected_by": { "type": "string" },
    "reason": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "required": ["skill_id", "rejected_by", "reason"]
}
